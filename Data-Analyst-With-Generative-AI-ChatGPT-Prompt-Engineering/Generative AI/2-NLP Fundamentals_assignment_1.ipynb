# Import required libraries
import nltk
import pandas as pd

from nltk.tokenize import word_tokenize, sent_tokenize
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer, WordNetLemmatizer
from nltk import pos_tag

from sklearn.feature_extraction.text import TfidfVectorizer, CountVectorizer
from sklearn.preprocessing import OneHotEncoder

# Download required NLTK resources (run once)
nltk.download('punkt')
nltk.download('stopwords')
nltk.download('wordnet')
nltk.download('averaged_perceptron_tagger')

# Sample Dataset (You can replace with your dataset)
text = """
Natural Language Processing (NLP) is a field of Artificial Intelligence.
It helps machines understand human language.
NLP is widely used in chatbots, translation, and sentiment analysis.
"""

print("\nOriginal Text:\n", text)

# -------------------------------
# 1. Tokenization
# -------------------------------
sent_tokens = sent_tokenize(text)
word_tokens = word_tokenize(text)

print("\nSentence Tokens:\n", sent_tokens)
print("\nWord Tokens:\n", word_tokens)

# -------------------------------
# 2. Stopwords Removal
# -------------------------------
stop_words = set(stopwords.words('english'))

filtered_tokens = [word for word in word_tokens if word.lower() not in stop_words]

print("\nTokens after Stopword Removal:\n", filtered_tokens)

# -------------------------------
# 3. Stemming
# -------------------------------
stemmer = PorterStemmer()

stemmed_words = [stemmer.stem(word) for word in filtered_tokens]

print("\nStemmed Words:\n", stemmed_words)

# -------------------------------
# 4. Lemmatization
# -------------------------------
lemmatizer = WordNetLemmatizer()

lemmatized_words = [lemmatizer.lemmatize(word) for word in filtered_tokens]

print("\nLemmatized Words:\n", lemmatized_words)

# -------------------------------
# 5. POS Tagging
# -------------------------------
pos_tags = pos_tag(filtered_tokens)

print("\nPOS Tags:\n", pos_tags)

# -------------------------------
# 6. TF-IDF Vectorization
# -------------------------------
tfidf_vectorizer = TfidfVectorizer()

tfidf_matrix = tfidf_vectorizer.fit_transform([text])

print("\nTF-IDF Feature Names:\n", tfidf_vectorizer.get_feature_names_out())
print("\nTF-IDF Matrix:\n", tfidf_matrix.toarray())

# -------------------------------
# 7. One-Hot Encoding
# -------------------------------
# Convert tokens into DataFrame
df = pd.DataFrame(filtered_tokens, columns=['Words'])

encoder = OneHotEncoder(sparse_output=False)

one_hot_encoded = encoder.fit_transform(df)

print("\nOne-Hot Encoded Matrix:\n", one_hot_encoded)

# -------------------------------
# 8. Bag of Words
# -------------------------------
bow_vectorizer = CountVectorizer()

bow_matrix = bow_vectorizer.fit_transform([text])

print("\nBag of Words Features:\n", bow_vectorizer.get_feature_names_out())
print("\nBag of Words Matrix:\n", bow_matrix.toarray())

# -------------------------------
# 9. N-grams (Unigram, Bigram, Trigram)
# -------------------------------

# Unigram
unigram = CountVectorizer(ngram_range=(1,1))
uni_matrix = unigram.fit_transform([text])

print("\nUnigram:\n", unigram.get_feature_names_out())

# Bigram
bigram = CountVectorizer(ngram_range=(2,2))
bi_matrix = bigram.fit_transform([text])

print("\nBigram:\n", bigram.get_feature_names_out())

# Trigram
trigram = CountVectorizer(ngram_range=(3,3))
tri_matrix = trigram.fit_transform([text])

print("\nTrigram:\n", trigram.get_feature_names_out())
